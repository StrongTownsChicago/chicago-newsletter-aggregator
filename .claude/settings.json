{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/bash-tool-damage-control.py",
            "statusMessage": "Validating command safety..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/edit-tool-damage-control.py",
            "statusMessage": "Checking file permissions..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/write-tool-damage-control.py",
            "statusMessage": "Checking file permissions..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/read-tool-damage-control.py",
            "statusMessage": "Checking file permissions..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/post-agent-quality-gate.py",
            "statusMessage": "Running quality checks on changed code (linting, tests)...",
            "timeout": 400
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=* of=/dev/*:*)"
    ],
    "ask": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(uv add *)",
      "Bash(uv remove *)",
      "Bash(pip install *)",
      "Bash(pip uninstall *)",
      "Bash(npm install *)",
      "Bash(npm uninstall *)",
      "Bash(npm i *)",
      "Bash(npm un *)",
      "Bash(npx *)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(pnpm add *)",
      "Bash(pnpm remove *)"
    ]
  }
}
