{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/bash-tool-damage-control.py",
            "statusMessage": "Validating command safety..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/edit-tool-damage-control.py",
            "statusMessage": "Checking file permissions..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/write-tool-damage-control.py",
            "statusMessage": "Checking file permissions..."
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/read-tool-damage-control.py",
            "statusMessage": "Checking file permissions..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "python .claude/hooks/check-project-health.py",
        "statusMessage": "Running project health checks (linting, tests)...",
        "timeout": 400
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(sudo rm -rf:*)",
      "Bash(mkfs:*)",
      "Bash(dd if=* of=/dev/*:*)"
    ],
    "ask": ["Bash(git push --force:*)", "Bash(git reset --hard:*)"]
  }
}
